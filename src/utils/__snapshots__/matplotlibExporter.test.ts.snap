exports[`single-chart matplotlib snapshot (Task 4.5 guard) > single-chart matplotlib output is stable 1`] = `
"#!/usr/bin/env python3
"""
Generated by plot3d.xyz
Chart: Sample Chart

Requirements: numpy, matplotlib (pip install numpy matplotlib)
"""
import numpy as np
import matplotlib
import matplotlib.pyplot as plt

# ─── Data ──────────────────────────────────────────────────────
x0 = np.array([1, 2, 3, 4, 5])
y0 = np.array([10, 20, 30, 40, 50])

# ─── Figure ────────────────────────────────────────────────────
fig, ax = plt.subplots(figsize=(6.04, 4.79))

# ─── Traces ────────────────────────────────────────────────────
ax.plot(x0, y0, color='#0ea5e9', linewidth=2, linestyle='-', marker='o', markersize=4, label='y')

# ─── Axes & labels ────────────────────────────────────────────
ax.set_title('Sample Chart')
ax.set_xlabel('X (s)')
ax.set_ylabel('Y')
ax.grid(True, which='both', linestyle='-', alpha=0.3)

# ─── Legend ────────────────────────────────────────────────────
ax.legend(loc='upper center', frameon=False)

# ─── Save & show ──────────────────────────────────────────────
plt.tight_layout()
plt.savefig('Sample Chart.png', dpi=300, bbox_inches='tight')
plt.show()
"
